{
  "version": 2,
  "name": "xinfengxinan",
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/products", "destination": "/products.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/sample-request", "destination": "/sample-request.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
